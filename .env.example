# =============================================================================
# TEXTOPRO — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Base de données PostgreSQL
# Settings > Database > Connection string
# -----------------------------------------------------------------------------
# "Transaction" pooler (port 6543) — pour l'app en runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# "Direct connection" (port 5432) — uniquement pour "npx prisma db push"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NEXTAUTH — Authentification
# Générer NEXTAUTH_SECRET avec: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="https://sms.numerik360.com"

# -----------------------------------------------------------------------------
# LETEXTO — Provider SMS (API HTTP uniquement — confidentiel, jamais au frontend)
# Disponible dans: tableau de bord LeTexto > API Développeur > Clés API
# -----------------------------------------------------------------------------
LETEXTO_API_KEY="your_letexto_api_key_here"
LETEXTO_API_URL="https://apis.letexto.com/v1"

# URL de votre serveur pour recevoir les accusés de réception SMS (DLR)
LETEXTO_DLR_URL="https://sms.numerik360.com/api/webhooks/dlr"
LETEXTO_DLR_METHOD="POST"

# -----------------------------------------------------------------------------
# PAYDUNYA — Paiement mobile (Orange Money, MTN, Wave, Moov, Free Money)
# Disponible dans: tableau de bord PayDunya > Paramètres > Clés API
# Clé Principale = MASTER_KEY / Clé Privée = PRIVATE_KEY / Token = TOKEN
# (La "Clé Publique" est pour le SDK JS côté client — non utilisée ici)
# -----------------------------------------------------------------------------
PAYDUNYA_MASTER_KEY="your_master_key"
PAYDUNYA_PRIVATE_KEY="your_private_key"
PAYDUNYA_TOKEN="your_token"

# "test" pour les tests, "live" pour la production
PAYDUNYA_MODE="test"

# URLs de callback — doivent être accessibles publiquement par PayDunya
# IPN = Endpoint de notification (webhook PayDunya envoie une requête POST ici)
PAYDUNYA_NOTIFY_URL="https://sms.numerik360.com/api/webhooks/paydunya"
PAYDUNYA_RETURN_URL="https://sms.numerik360.com/recharge/success"
PAYDUNYA_CANCEL_URL="https://sms.numerik360.com/recharge/cancel"

# Infos affichées sur la page de paiement PayDunya
PAYDUNYA_STORE_NAME="TextoPro"
PAYDUNYA_STORE_TAGLINE="Plateforme SMS Marketing"
PAYDUNYA_STORE_PHONE="+2250000000000"
PAYDUNYA_STORE_POSTAL_ADDRESS="Abidjan, Côte d'Ivoire"
PAYDUNYA_STORE_WEBSITE_URL="https://sms.numerik360.com"

# -----------------------------------------------------------------------------
# APP — Configuration
# Le prix SMS est géré dans le panel admin (AppConfig en base) — pas en .env
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="TextoPro"
