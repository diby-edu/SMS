generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // URL avec pooler pour les requêtes runtime (Supabase Pooler)
  url       = env("DATABASE_URL")
  // URL directe pour les migrations Prisma
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  CLIENT
}

enum SenderStatus {
  PENDING    // En attente de validation admin (étape 1)
  SUBMITTED  // Soumis à LeTexto / opérateurs télécom (étape 2)
  APPROVED   // Validé par les opérateurs, actif (étape 3)
  REJECTED   // Refusé (par admin ou opérateurs)
  DISABLED   // Désactivé par l'admin (était APPROVED)
}

enum MessageStatus {
  PENDING    // En attente d'envoi
  SENT       // Envoyé au réseau
  DELIVERED  // Délivré au destinataire
  FAILED     // Échec d'envoi
}

enum CampaignStatus {
  CREATED  // Créée, en cours d'envoi
  SENDING  // En cours d'envoi
  SENT     // Envoyée
  FAILED   // Échec
}

enum TransactionStatus {
  PENDING  // En attente de confirmation PayDunya
  SUCCESS  // Paiement confirmé, crédits attribués
  FAILED   // Paiement échoué ou annulé
}

enum TransactionType {
  AUTOMATIQUE  // Via PayDunya
  MANUELLE     // Crédit admin
}

enum OtpStatus {
  PENDING   // Code envoyé, pas encore vérifié
  VERIFIED  // Code vérifié avec succès
  EXPIRED   // Code expiré
  FAILED    // Trop de tentatives
}

// ============================================================
// MODÈLES
// ============================================================

model User {
  id         String   @id @default(cuid())
  nom        String
  prenom     String
  email      String   @unique
  phone      String
  pays       String   // Code pays ISO, ex: "CI", "SN", "ML"
  password   String   // Hash bcrypt
  role       Role     @default(CLIENT)
  solde_sms  Int      @default(0) // Solde en nombre de SMS
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  senders        Sender[]
  contacts       Contact[]
  contactLists   ContactList[]
  messages       Message[]
  campaigns      Campaign[]
  transactions   Transaction[]
  apiKeys        ApiKey[]
  chariowConfigs ChariowConfig[]

  @@map("users")
}

model Sender {
  id              String       @id @default(cuid())
  user_id         String
  nom             String       @db.VarChar(11) // Max 11 caractères imposé par les opérateurs
  statut          SenderStatus @default(PENDING)
  type_message    String?      // PROMOTIONAL | OTP | TRANSACTIONAL
  description     String?      // Description du contenu des messages
  email_contact   String?      // Email de contact du client
  site_web        String?      // Site web ou application liée au sender
  adresse         String?      // Adresse de l'entreprise
  siege_social    String?      // Siège social
  exemple_message String?      // Exemple(s) de message
  activite        String?      // Secteur d'activité
  created_at      DateTime     @default(now())

  user      User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@map("senders")
}

model ContactList {
  id         String   @id @default(cuid())
  user_id    String
  nom        String
  created_at DateTime @default(now())

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  contacts Contact[]

  @@map("contact_lists")
}

model Contact {
  id         String   @id @default(cuid())
  user_id    String
  liste_id   String?
  nom        String?
  prenom     String?
  phone      String   // Format international obligatoire : +2250707000000
  pays       String   // Code pays ISO, ex: "CI"
  created_at DateTime @default(now())

  user  User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  liste ContactList? @relation(fields: [liste_id], references: [id], onDelete: SetNull)

  @@map("contacts")
}

model Message {
  id           String        @id @default(cuid())
  user_id      String
  api_key_id   String?       // Si envoyé via API publique (SMS Transactionnel)
  sender       String        // Nom de l'expéditeur affiché
  destinataire String        // Numéro en format international
  contenu      String
  statut       MessageStatus @default(PENDING)
  letexto_id   String?       // ID retourné par l'API LeTexto
  cost_sms     Int           @default(1) // Nombre de SMS consommés (1 SMS = 160 chars)
  created_at   DateTime      @default(now())

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [api_key_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([api_key_id])
  @@index([letexto_id])
  @@map("messages")
}

model Campaign {
  id          String         @id @default(cuid())
  user_id     String
  label       String
  sender_id   String?        // Référence au sender (nullable si supprimé)
  sender_nom  String         // Copie du nom pour l'historique
  contenu     String
  nb_contacts Int            @default(0)
  nb_success  Int            @default(0)
  nb_failed   Int            @default(0)
  statut      CampaignStatus @default(CREATED)
  letexto_id  String?        // ID de la campagne chez LeTexto
  cost_sms    Int            @default(0) // Total SMS débités
  created_at  DateTime       @default(now())

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sender Sender? @relation(fields: [sender_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@map("campaigns")
}

model Transaction {
  id             String            @id @default(cuid())
  user_id        String
  montant_fcfa   Int               // Montant payé en FCFA (0 pour crédit manuel)
  sms_credites   Int               // Nombre de SMS crédités
  statut         TransactionStatus @default(PENDING)
  type           TransactionType   @default(AUTOMATIQUE)
  note           String?           // Note admin pour crédit manuel
  paydunya_token String?           // Token de la facture PayDunya
  paydunya_data  Json?             // Données brutes de l'IPN PayDunya
  created_at     DateTime          @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([paydunya_token])
  @@map("transactions")
}

// Clé API générée par le client pour utiliser l'API TextoPro (OTP + SMS Transactionnel)
model ApiKey {
  id                           String    @id @default(cuid())
  user_id                      String
  name                         String    // Nom de l'application (ex: "Mon App Mobile")
  key                          String    @unique // Format: tp_live_xxxxxxxxxxxxxxxxxxxx
  is_active                    Boolean   @default(true)
  default_otp_sender           String?   // Nom du sender OTP par défaut
  default_transactional_sender String?   // Nom du sender Transactionnel par défaut
  dlr_webhook_url              String?   // URL de callback pour les accusés de livraison
  last_used                    DateTime?
  created_at                   DateTime  @default(now())

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  otpCodes OtpCode[]
  messages Message[]

  @@index([key])
  @@map("api_keys")
}

// Code OTP généré et envoyé via l'API TextoPro
model OtpCode {
  id          String    @id @default(cuid())
  api_key_id  String
  phone       String    // Numéro destinataire (format international)
  code        String    // Code à 6 chiffres
  statut      OtpStatus @default(PENDING)
  attempts    Int       @default(0) // Nombre de tentatives de vérification
  expires_at  DateTime  // Expiration (5 minutes après création)
  verified_at DateTime? // Date de vérification réussie
  created_at  DateTime  @default(now())

  apiKey ApiKey @relation(fields: [api_key_id], references: [id], onDelete: Cascade)

  @@index([api_key_id])
  @@index([phone])
  @@map("otp_codes")
}

// Intégration Chariow — webhook pulse → SMS automatique
model ChariowConfig {
  id               String   @id @default(cuid())
  user_id          String
  sender           String   // Nom du sender APPROVED à utiliser pour les SMS
  token            String   @unique // Token secret pour l'URL webhook publique
  events_disabled  String[] @default([]) // Événements désactivés (vide = tous actifs)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
  @@map("chariow_configs")
}

// Configuration globale de la plateforme (une seule ligne)
model AppConfig {
  id                    String   @id @default(cuid())
  prix_sms_fcfa         Int      @default(30)   // Prix de vente client (taux de base, < premier palier)
  letexto_balance_alert Int      @default(1000) // Seuil d'alerte solde LeTexto
  montant_minimum       Int      @default(500)  // Montant minimum de recharge (FCFA)
  montants_rapides      Json     @default("[1000,3000,5000,10000,25000,50000]") // Montants rapides affichés sur la page recharge
  paliers_prix          Json     @default("[{\"montant\":10000,\"taux\":30},{\"montant\":25000,\"taux\":28},{\"montant\":50000,\"taux\":26},{\"montant\":100000,\"taux\":24},{\"montant\":500000,\"taux\":21},{\"montant\":1000000,\"taux\":20}]") // Paliers de tarification dégressive
  updated_at            DateTime @updatedAt

  @@map("app_config")
}
